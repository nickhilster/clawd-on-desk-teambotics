{
  "schemaVersion": 1,
  "name": "Codex",
  "author": "Teambotics",
  "version": "0.1.0",
  "description": "The Codex character — a personified OpenAI bloom mark. Prototype.",

  "viewBox": {
    "x": -15,
    "y": -25,
    "width": 45,
    "height": 45
  },

  "layout": {
    "contentBox": { "x": 0, "y": -8, "width": 15, "height": 18 },
    "centerX": 7.5,
    "baselineY": 14,
    "visibleHeightRatio": 0.55,
    "baselineBottomRatio": 0.04
  },

  "eyeTracking": {
    "enabled": false
  },

  "states": {
    "idle":         ["codex-working-flow.svg"],
    "thinking":     ["codex-working-flow.svg"],
    "working":      ["codex-working-flow.svg"],
    "juggling":     ["codex-working-flow.svg"],
    "error":        { "fallbackTo": "attention" },
    "attention":    ["codex-working-flow.svg"],
    "notification": { "fallbackTo": "attention" },
    "sleeping":     { "fallbackTo": "attention" },
    "waking":       ["codex-working-flow.svg"]
  },

  "sleepSequence": { "mode": "direct" },

  "hitBoxes": {
    "default": { "x": 4, "y": -3, "w": 7, "h": 7 }
  },

  "miniMode": { "supported": false },

  "objectScale": {
    "widthRatio": 1.9,
    "heightRatio": 1.3,
    "offsetX": -0.45,
    "offsetY": -0.25
  }
}
