{
  "schemaVersion": 1,
  "name": "DeskBuddy — MDM",
  "author": "Teambotics",
  "version": "1.0.0",
  "description": "Overloaded but willing — the MDown Manager mascot for mdownmanager.com",
  "viewBox": {
    "x": -15,
    "y": -25,
    "width": 45,
    "height": 45
  },
  "layout": {
    "contentBox": { "x": -4, "y": -10, "width": 24, "height": 25 },
    "centerX": 7.5,
    "baselineY": 15,
    "visibleHeightRatio": 0.58,
    "baselineBottomRatio": 0.05
  },
  "eyeTracking": {
    "enabled": true,
    "states": ["idle"],
    "eyeRatioX": 0.5,
    "eyeRatioY": 0.5,
    "maxOffset": 3,
    "bodyScale": 0.33,
    "shadowStretch": 0.15,
    "shadowShift": 0.3,
    "ids": {
      "eyes": "eyes-js",
      "body": "body-js",
      "shadow": "mdm_shadow"
    },
    "shadowOrigin": "7.5px 15.3px"
  },
  "sleepSequence": {
    "mode": "direct"
  },
  "states": {
    "idle": ["mdm-idle-follow.svg"],
    "thinking": ["mdm-thinking.svg"],
    "working": ["mdm-working-typing.svg"],
    "juggling": ["mdm-working-juggling.svg"],
    "sweeping": ["mdm-working-sweeping.svg"],
    "error": ["mdm-error.svg"],
    "attention": ["mdm-happy.svg"],
    "notification": ["mdm-notification.svg"],
    "carrying": ["mdm-working-carrying.svg"],
    "sleeping": ["mdm-sleeping.svg"]
  },
  "workingTiers": [
    { "minSessions": 3, "file": "mdm-working-building.svg" },
    { "minSessions": 2, "file": "mdm-working-juggling.svg" },
    { "minSessions": 1, "file": "mdm-working-typing.svg" }
  ],
  "jugglingTiers": [
    { "minSessions": 2, "file": "mdm-working-conducting.svg" },
    { "minSessions": 1, "file": "mdm-working-juggling.svg" }
  ],
  "idleAnimations": [
    { "file": "mdm-idle-look.svg", "duration": 6500 },
    { "file": "mdm-idle-bubble.svg", "duration": 13500 },
    { "file": "mdm-idle-reading.svg", "duration": 14000 }
  ],
  "reactions": {
    "drag": { "file": "mdm-react-drag.svg" },
    "clickLeft": { "file": "mdm-react-left.svg", "duration": 2500 },
    "clickRight": { "file": "mdm-react-right.svg", "duration": 2500 },
    "annoyed": { "file": "mdm-react-annoyed.svg", "duration": 3500 },
    "double": { "files": ["mdm-react-double.svg"], "duration": 3500 }
  },
  "timings": {
    "minDisplay": {
      "attention": 4000,
      "error": 5000,
      "sweeping": 5500,
      "notification": 5000,
      "carrying": 3000,
      "working": 1000,
      "thinking": 1000
    },
    "autoReturn": {
      "attention": 4000,
      "error": 5000,
      "sweeping": 300000,
      "notification": 5000,
      "carrying": 3000
    },
    "mouseIdleTimeout": 20000,
    "mouseSleepTimeout": 60000
  },
  "hitBoxes": {
    "default": { "x": -1, "y": 5, "w": 17, "h": 12 },
    "sleeping": { "x": -2, "y": 9, "w": 19, "h": 7 },
    "wide": { "x": -3, "y": 3, "w": 21, "h": 14 }
  },
  "wideHitboxFiles": ["mdm-error.svg", "mdm-notification.svg"],
  "sleepingHitboxFiles": ["mdm-sleeping.svg"],
  "sounds": {
    "complete": "complete.mp3",
    "confirm": "confirm.mp3"
  },
  "miniMode": {
    "supported": true,
    "offsetRatio": 0.486,
    "states": {
      "mini-idle": ["mdm-mini-idle.svg"],
      "mini-alert": ["mdm-mini-alert.svg"],
      "mini-happy": ["mdm-mini-happy.svg"],
      "mini-enter": ["mdm-mini-enter.svg"],
      "mini-peek": ["mdm-mini-peek.svg"],
      "mini-working": ["mdm-mini-typing.svg"],
      "mini-crabwalk": ["mdm-mini-crabwalk.svg"],
      "mini-enter-sleep": ["mdm-mini-enter-sleep.svg"],
      "mini-sleep": ["mdm-mini-sleep.svg"]
    },
    "timings": {
      "minDisplay": { "mini-alert": 4000, "mini-happy": 4000 },
      "autoReturn": { "mini-alert": 4000, "mini-happy": 4000 }
    }
  },
  "objectScale": {
    "widthRatio": 1.9,
    "heightRatio": 1.3,
    "offsetX": -0.45,
    "offsetY": -0.25
  }
}
